      html += `
        <div class="nav-link" onclick="App.navigate('student-dash')" id="nav-student-dash"><i class="fas fa-th-large"></i> My Dashboard</div>
        <div class="nav-link" onclick="App.navigate('student-inbox')" id="nav-student-inbox"><i class="fas fa-envelope"></i> My Inbox</div>
        <div class="nav-link" onclick="App.navigate('student-exams')" id="nav-student-exams"><i class="fas fa-file-signature"></i> My Exams</div>
        <div class="nav-link" onclick="App.navigate('student-results')" id="nav-student-results"><i class="fas fa-chart-bar"></i> Exam Reports</div>
        <div class="nav-link" onclick="App.navigate('student-videos')" id="nav-student-videos"><i class="fas fa-play-circle"></i> Videos / Materials</div>
