  navigate(view) {
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
    
    const el = document.getElementById('view-' + view);
    if (el) el.classList.add('active');
    
    const nav = document.getElementById('nav-' + view);
    if (nav) nav.classList.add('active');
    
    this.currentView = view;
    if(this.timerInterval && view !== 'student-take') clearInterval(this.timerInterval);

    if (view === 'admin-dash') this.loadAdminDash();
    if (view === 'admin-depts') this.loadAdminDepts();
    if (view === 'admin-exams') this.loadAdminExams();
    if (view === 'admin-videos') this.loadAdminVideos();
    if (view === 'admin-messages') this.loadAdminMessages();

    if (view === 'student-dash') this.loadStudentDash();
    if (view === 'student-exams') this.loadStudentExams();
    if (view === 'student-results') this.loadStudentResults();
    if (view === 'student-inbox') this.loadStudentInbox();
    if (view === 'student-videos') this.loadStudentVideos();
  },

  // --- Admin Flow ---
  async loadAdminDash() {
    const res = await this.api('/api/admin/dashboard');
    if(res.error) return this.toast(res.error);
    
    if(this.charts.pie) this.charts.pie.destroy();
    this.charts.pie = new Chart(document.getElementById('adminPieChart'), {
      type: 'pie',
      data: { labels: ['Passed', 'Failed'], datasets: [{ data: [res.passed, res.failed], backgroundColor: ['#7bb033', '#d93025'] }] },
      options: { responsive: true, maintainAspectRatio: false }
    });

    const labels = Object.keys(res.examScores);
    const data = labels.map(l => Math.round(res.examScores[l].total / res.examScores[l].count));
    
    if(this.charts.bar) this.charts.bar.destroy();
    this.charts.bar = new Chart(document.getElementById('adminBarChart'), {
      type: 'bar',
      data: { labels, datasets: [{ label: 'Avg Score %', data, backgroundColor: '#0f5298' }] },
      options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, max: 100 } } }
    });
  },

  async loadAdminDepts() {
    const depts = await this.api('/api/departments');
    let html = `<table><tr><th>Department Name</th><th>Action</th></tr>`;
    depts.forEach(d => {
      html += `<tr><td>${d.name}</td><td><button class="btn btn-danger btn-sm" onclick="App.deleteDepartment('${d._id}')">Delete</button></td></tr>`;
    });
    html += `</table>`;
    document.getElementById('adminDeptList').innerHTML = depts.length ? html : '<p>No departments.</p>';
  },
  async addDepartment(e) {
    e.preventDefault();
    const res = await this.api('/api/admin/departments', 'POST', { name: document.getElementById('newDeptName').value });
    if(res.error) return this.toast(res.error);
    this.toast('Department added');
    document.getElementById('newDeptName').value = '';
    this.loadAdminDepts();
    this.loadDepartments(); // refresh global dropdowns
  },
  async deleteDepartment(id) {
    if(!confirm('Delete this department?')) return;
    await this.api(`/api/admin/departments/${id}`, 'DELETE');
    this.toast('Deleted');
    this.loadAdminDepts();
    this.loadDepartments();
  },

  async loadAdminExams() {
    const res = await this.api('/api/admin/dashboard');
    if(res.error) return;
    
    let html = `<table><tr><th>Title</th><th>Dept</th><th>Duration</th><th>Action</th></tr>`;
    res.exams.forEach(e => {
      html += `<tr>
        <td><strong>${this.esc(e.title)}</strong></td>
        <td>${this.esc(e.department)}</td>
        <td>${e.duration}m</td>
        <td>
          <button class="btn btn-blue btn-sm" onclick="App.viewAdminExam('${e._id}')">Edit</button>
          <button class="btn btn-green btn-sm" onclick="App.viewAdminSubs('${e._id}')">Results</button>
        </td>
      </tr>`;
    });
    html += `</table>`;
    document.getElementById('adminExamList').innerHTML = res.exams.length ? html : '<p>No exams created yet.</p>';
  },

  async createExam(e) {
    e.preventDefault();
    const body = {
      title: document.getElementById('exTitle').value,
      description: document.getElementById('exDesc').value,
      department: document.getElementById('exDept').value,
      duration: document.getElementById('exDuration').value,
      passingPercentage: document.getElementById('exPass').value
    };
    const res = await this.api('/api/admin/exams', 'POST', body);
    if(res.error) return this.toast(res.error);
    this.toast('Exam Created');
    this.viewAdminExam(res.exam._id);
  },

  async viewAdminExam(id) {
    const res = await this.api(`/api/admin/exams/${id}`);
    if(res.error) return this.toast(res.error);
    this.currentExam = res.exam;
    this.navigate('admin-exam-detail');
    
    document.getElementById('adminExamHeader').innerHTML = `
      <div><h2 style="color:var(--theme-dark)">${this.esc(res.exam.title)}</h2><p>${this.esc(res.exam.department)} | ${res.exam.duration} mins</p></div>
      <button class="btn btn-outline" onclick="App.navigate('admin-exams')">Back</button>
    `;
    this.renderAdminQs();
  },

  toggleQType() {
    const t = document.getElementById('qType').value;
    document.getElementById('mcqSection').style.display = t === 'mcq' ? 'block' : 'none';
    document.getElementById('qFileSection').style.display = t === 'file' ? 'block' : 'none';
    ['qO0','qO1'].forEach(id => document.getElementById(id).required = t === 'mcq');
  },

  handleAdminQFile(e) {
    const file = e.target.files[0];
    if(!file) return;
    if(file.size > 5 * 1024 * 1024) return this.toast('File too large. Max 5MB.');
    const reader = new FileReader();
    reader.onload = (ev) => { document.getElementById('qFileBase64').value = ev.target.result; };
    reader.readAsDataURL(file);
  },

  async addQuestion(e) {
    e.preventDefault();
    const type = document.getElementById('qType').value;
    const body = { type, questionText: document.getElementById('qText').value, marks: document.getElementById('qMarks').value };
    if (type === 'mcq') {
      body.options = [document.getElementById('qO0').value, document.getElementById('qO1').value, document.getElementById('qO2').value, document.getElementById('qO3').value];
      body.correctAnswer = document.getElementById('qCorrect').value;
    } else {
      body.questionFile = document.getElementById('qFileBase64').value;
      if(!body.questionFile) return this.toast('Please select a file.');
    }

    const res = await this.api(`/api/admin/exams/${this.currentExam._id}/questions`, 'POST', body);
    if(res.error) return this.toast(res.error);
    this.currentExam = res.exam;
    this.toast('Question added');
    e.target.reset();
    document.getElementById('qFileBase64').value = '';
    this.toggleQType();
    this.renderAdminQs();
  },

  async deleteQuestion(examId, idx) {
    if(!confirm('Delete this question?')) return;
    const res = await this.api(`/api/admin/exams/${examId}/questions/${idx}`, 'DELETE');
    if(res.error) return this.toast(res.error);
    this.currentExam = res.exam;
    this.toast('Question deleted');
    this.renderAdminQs();
  },

  renderAdminQs() {
    let html = '';
    this.currentExam.questions.forEach((q, i) => {
      html += `<div style="border-bottom:1px solid #eee; padding-bottom:10px; margin-bottom:10px;">
        <div style="display:flex; justify-content:space-between;">
          <strong>Q${i+1}: ${this.esc(q.questionText)}</strong>
          <button class="btn btn-danger btn-sm" onclick="App.deleteQuestion('${this.currentExam._id}', ${i})"><i class="fas fa-trash"></i></button>
        </div>
        <div style="font-size:12px; color:var(--text-muted)">${q.marks} marks - [${q.type.toUpperCase()}]</div>`;
      
      if(q.type === 'mcq') {
        html += `<ul style="margin-left:20px; font-size:13px; color:var(--text-muted)">`;
        q.options.forEach((o, j) => {
          html += `<li style="${j === q.correctAnswer ? 'color:var(--green);font-weight:bold;' : ''}">${this.esc(o)}</li>`;
        });
        html += `</ul>`;
      } else if (q.questionFile) {
        html += `<div style="margin-top:10px; font-size:12px;"><a href="${q.questionFile}" target="_blank" style="color:var(--theme-dark)">View Attached File</a></div>`;
      }
      html += `</div>`;
    });
    document.getElementById('adminQuestionList').innerHTML = html || '<p>No questions added.</p>';
  },

  async viewAdminSubs(id) {
    const res = await this.api(`/api/admin/exams/${id}/submissions`);
    if(res.error) return this.toast(res.error);
    this.navigate('admin-subs');
    
    let html = `<div style="display:flex;justify-content:space-between;margin-bottom:15px">
      <h2>Results: ${this.esc(res.exam.title)}</h2>
      <button class="btn btn-outline" onclick="App.navigate('admin-exams')">Back</button>
    </div>
    <table><tr><th>Student</th><th>Score</th><th>Status</th><th>Review</th></tr>`;
    
    res.submissions.forEach(s => {
      let stat = s.passed ? '<span class="badge badge-pass">Pass</span>' : '<span class="badge badge-fail">Fail</span>';
      if(s.needsManualGrading) stat = '<span class="badge" style="background:var(--orange)">Needs Review</span>';
      
      html += `<tr>
        <td>${this.esc(s.user.name)} <br><small>${s.user.studentId}</small></td>
        <td>${s.score}/${s.totalMarks} (${s.percentage}%)</td>
        <td>${stat}</td>
        <td><button class="btn btn-blue btn-sm" onclick="App.gradeSubmission('${s._id}')">View</button></td>
      </tr>`;
    });
    html += `</table>`;
    document.getElementById('adminSubsContent').innerHTML = html;
  },
  async gradeSubmission(id) {
    const newScore = prompt("Enter the new absolute total score for this student (out of Total Marks):");
    if(newScore !== null && !isNaN(newScore)) {
      const res = await this.api(`/api/admin/submissions/${id}/grade`, 'PUT', { score: parseInt(newScore) });
      if(!res.error) {
        this.toast("Graded successfully");
        this.viewAdminSubs(res.sub.exam);
      }
    }
  },

  // Videos
  parseYoutubeEmbed(url) {
    let vidId = '';
    if (url.includes('youtube.com/watch?v=')) vidId = url.split('v=')[1].split('&')[0];
    else if (url.includes('youtu.be/')) vidId = url.split('youtu.be/')[1].split('?')[0];
    return vidId ? `https://www.youtube.com/embed/${vidId}` : url;
  },
  async loadAdminVideos() {
    const vids = await this.api('/api/videos');
    let html = '';
    vids.forEach(v => {
      html += `<div class="video-card">
        <h4>${this.esc(v.title)}</h4>
        <iframe src="${this.parseYoutubeEmbed(v.youtubeUrl)}" allowfullscreen></iframe>
        <button class="btn btn-danger btn-sm" style="margin-top:10px; width:100%;" onclick="App.deleteVideo('${v._id}')">Delete</button>
      </div>`;
    });
    document.getElementById('adminVideoList').innerHTML = html || '<p>No videos found.</p>';
  },
  async addVideo(e) {
    e.preventDefault();
    const body = { title: document.getElementById('vidTitle').value, youtubeUrl: document.getElementById('vidUrl').value };
    await this.api('/api/admin/videos', 'POST', body);
    this.toast('Video added');
    e.target.reset();
    this.loadAdminVideos();
  },
  async deleteVideo(id) {
    if(!confirm('Delete video?')) return;
    await this.api(`/api/admin/videos/${id}`, 'DELETE');
    this.toast('Deleted');
    this.loadAdminVideos();
  },

  // Messages
  async loadAdminMessages() {
    const students = await this.api('/api/admin/students');
    let html = '';
    students.forEach(s => html += `<option value="${s._id}">${s.name} (${s.studentId} - ${s.department})</option>`);
    document.getElementById('msgStudent').innerHTML = html;
  },
  async sendMessage(e) {
    e.preventDefault();
    const body = { 
      toStudent: document.getElementById('msgStudent').value, 
      subject: document.getElementById('msgSubject').value, 
      body: document.getElementById('msgBody').value 
    };
    await this.api('/api/admin/messages', 'POST', body);
    this.toast('Message sent to student');
    e.target.reset();
  },


  // --- Student Flow ---
  async uploadProfilePhoto(e) {
    const file = e.target.files[0];
    if(!file) return;
    if(file.size > 2 * 1024 * 1024) return this.toast('Image too large. Max 2MB.');
    
    const reader = new FileReader();
    reader.onload = async (ev) => {
      const b64 = ev.target.result;
      const res = await this.api('/api/user/profile', 'POST', { profilePhoto: b64 });
      if(res.ok) {
         this.user.profilePhoto = b64;
         document.getElementById('dashAvatar').src = b64;
         this.toast('Profile updated');
      }
    };
    reader.readAsDataURL(file);
  },

  async loadStudentDash() {
    const res = await this.api('/api/student/dashboard');
    if(res.error) return this.toast(res.error);
    
    document.getElementById('dashName').innerText = this.user.name;
    document.getElementById('dashStId').innerText = `(${this.user.studentId})`;
    if(this.user.profilePhoto) document.getElementById('dashAvatar').src = this.user.profilePhoto;
    
    document.getElementById('dashExamCount').innerText = res.submissions.length;
    document.getElementById('dashInboxCount').innerText = res.msgCount || 0;

    if(this.charts.line) this.charts.line.destroy();
    this.charts.line = new Chart(document.getElementById('studentLineChart'), {
      type: 'line',
      data: { labels: res.chartLabels, datasets: [{ label: 'Score %', data: res.chartData, borderColor: '#33b89e', fill: false, tension: 0.1 }] },
      options: { responsive: true, maintainAspectRatio: false, scales: { y: { max: 100, min: 0 } } }
    });
  },

  async loadStudentExams() {
    const res = await this.api('/api/student/dashboard'); 
    if(res.error) return;
    
    let html = `<table><tr><th>Exam Title</th><th>Questions</th><th>Duration</th><th>Action</th></tr>`;
    res.exams.forEach(e => {
      const isDone = res.submissions.some(s => s.exam._id === e._id);
      html += `<tr>
        <td><strong>${this.esc(e.title)}</strong></td>
        <td>${e.questions.length} Qs</td>
        <td>${e.duration} mins</td>
        <td>
          ${isDone ? `<span class="badge badge-pass">Completed</span>` : 
           `<button class="btn btn-orange" onclick="App.startExam('${e._id}')"><i class="fas fa-play"></i> Start</button>`}
        </td>
      </tr>`;
    });
    html += `</table>`;
    document.getElementById('studentExamList').innerHTML = res.exams.length ? html : '<p>No exams available.</p>';
  },

  async startExam(id) {
    if(!confirm('Timer begins immediately. Ready?')) return;
    const res = await this.api(`/api/student/exams/${id}/start`, 'POST');
    if(res.error) return this.toast(res.error);
    
    this.currentExam = res.exam;
    this.currentSubmission = res.submission;
    this.currentQIdx = 0;
    
    const elapsed = Math.floor((Date.now() - new Date(this.currentSubmission.startedAt).getTime()) / 1000);
    this.timeRemaining = (this.currentExam.duration * 60) - elapsed;
    
    this.navigate('student-take');
    this.startTimer();
    this.renderTakeUI();
  },

  renderTakeUI() {
    const ex = this.currentExam;
    const q = ex.questions[this.currentQIdx];
    const ans = this.currentSubmission.answers[this.currentQIdx] || {};

    let html = `
      <div class="exam-header">
        <div><h3>${this.esc(ex.title)}</h3><p>Question ${this.currentQIdx+1} of ${ex.questions.length}</p></div>
        <div class="timer" id="takeTimer"><i class="fas fa-stopwatch"></i> <span id="tDisp">--:--</span></div>
      </div>
      <div class="exam-body">
        <div class="card" style="align-self:start">
          <h4>Map</h4>
          <div class="q-nav-grid">
            ${ex.questions.map((_, i) => {
               const st = this.currentSubmission.answers[i];
               let c = 'q-btn';
               if(i === this.currentQIdx) c += ' current';
               else if((st.selectedAnswer > -1) || st.answerFile) c += ' answered';
               return `<button class="${c}" onclick="App.goToQ(${i})">${i+1}</button>`;
            }).join('')}
          </div>
        </div>
        <div class="card">
          <h3 style="margin-bottom:15px">${this.esc(q.questionText)} <span style="font-size:12px; color:var(--text-muted); float:right">${q.marks} Mark(s)</span></h3>
    `;

    if (q.type === 'mcq') {
      q.options.forEach((o, i) => {
        const sel = ans.selectedAnswer === i ? 'selected' : '';
        html += `<div class="option-item ${sel}" onclick="App.selOpt(${i})">
          <div style="width:20px;height:20px;border-radius:50%;border:2px solid ${ans.selectedAnswer === i ? 'var(--theme-dark)' : '#ccc'}; background:${ans.selectedAnswer === i ? 'var(--theme-dark)' : 'transparent'}"></div>
          ${this.esc(o)}
        </div>`;
      });
    } else if (q.type === 'file') {
      if(q.questionFile) {
        let isImg = q.questionFile.startsWith('data:image');
        html += `<div class="file-preview">
          ${isImg ? `<img src="${q.questionFile}">` : `<embed src="${q.questionFile}" type="application/pdf">`}
        </div>`;
      }
      html += `
        <div style="margin-top:20px; padding:20px; background:#f0f7ff; border:1px dashed var(--theme-dark); border-radius:8px;">
          <h4 style="margin-bottom:10px">Upload Answer Sheet (PDF/Image)</h4>
          <input type="file" accept="image/*,application/pdf" onchange="App.handleStudentAnswerFile(event)">
          ${ans.answerFile ? `<p style="color:var(--green);margin-top:10px"><i class="fas fa-check"></i> File uploaded</p>` : ''}
        </div>
      `;
    }

    html += `
          <div style="display:flex; justify-content:space-between; margin-top:30px">
            <button class="btn btn-outline" ${this.currentQIdx===0?'disabled':''} onclick="App.goToQ(${this.currentQIdx-1})">Prev</button>
            ${this.currentQIdx < ex.questions.length-1 
              ? `<button class="btn btn-blue" onclick="App.goToQ(${this.currentQIdx+1})">Next</button>` 
              : `<button class="btn btn-green" onclick="App.submitExam()">Finish Exam</button>`}
          </div>
        </div>
      </div>
    `;
    document.getElementById('examTakeContent').innerHTML = html;
  },

  handleStudentAnswerFile(e) {
    const file = e.target.files[0];
    if(!file) return;
    if(file.size > 5 * 1024 * 1024) return this.toast('File too large. Max 5MB.');
    const reader = new FileReader();
    reader.onload = (ev) => {
      this.currentSubmission.answers[this.currentQIdx].answerFile = ev.target.result;
      this.renderTakeUI();
    };
    reader.readAsDataURL(file);
  },
  selOpt(idx) { this.currentSubmission.answers[this.currentQIdx].selectedAnswer = idx; this.renderTakeUI(); },
  goToQ(idx) { this.currentQIdx = idx; this.renderTakeUI(); },
  startTimer() {
    this.timerInterval = setInterval(() => {
      this.timeRemaining--;
      const min = Math.floor(this.timeRemaining / 60);
      const sec = this.timeRemaining % 60;
      const t = document.getElementById('tDisp');
      if(t) t.innerText = `${min}:${sec < 10 ? '0':''}${sec}`;
      if(this.timeRemaining <= 0) { clearInterval(this.timerInterval); this.submitExam(); }
    }, 1000);
  },
  async submitExam() {
    clearInterval(this.timerInterval);
    const res = await this.api(`/api/student/submissions/${this.currentSubmission._id}/submit`, 'POST', { answers: this.currentSubmission.answers });
    if(res.error) return this.toast(res.error);
    this.toast('Exam Submitted');
    this.navigate('student-results');
  },

  async loadStudentResults() {
    const res = await this.api('/api/student/dashboard'); 
    if(res.error) return;
    let html = `<table><tr><th>Exam</th><th>Score</th><th>Status</th></tr>`;
    res.submissions.forEach(s => {
      let stat = s.passed ? '<span class="badge badge-pass">Passed</span>' : '<span class="badge badge-fail">Failed</span>';
      if(s.needsManualGrading) stat = '<span class="badge" style="background:var(--orange)">Pending Grading</span>';
      html += `<tr>
        <td><strong>${this.esc(s.exam.title)}</strong></td>
        <td>${s.needsManualGrading ? 'TBD' : `${s.score}/${s.totalMarks} (${s.percentage}%)`}</td>
        <td>${stat}</td>
      </tr>`;
    });
    html += `</table>`;
    document.getElementById('studentResultsList').innerHTML = res.submissions.length ? html : '<p>No results yet.</p>';
  },

  async loadStudentInbox() {
    const msgs = await this.api('/api/messages');
    let html = '';
    msgs.forEach(m => {
      html += `<div style="padding:15px; border:1px solid #ddd; border-radius:8px; margin-bottom:10px;">
        <h4 style="margin-bottom:5px; color:var(--theme-dark);">${this.esc(m.subject)}</h4>
        <div style="font-size:12px; color:var(--text-muted); margin-bottom:10px;">From: ${m.fromAdmin?.name} - ${new Date(m.createdAt).toLocaleString()}</div>
        <p style="font-size:14px; white-space:pre-wrap;">${this.esc(m.body)}</p>
      </div>`;
    });
    document.getElementById('studentInboxList').innerHTML = msgs.length ? html : '<p>Your inbox is empty.</p>';
  },

  async loadStudentVideos() {
    const vids = await this.api('/api/videos');
    let html = '';
    vids.forEach(v => {
      html += `<div class="video-card">
        <h4>${this.esc(v.title)}</h4>
        <iframe src="${this.parseYoutubeEmbed(v.youtubeUrl)}" allowfullscreen></iframe>
      </div>`;
    });
    document.getElementById('studentVideoList').innerHTML = html || '<p>No videos available right now.</p>';
  },

  async api(url, method='GET', body=null) {
    try {
      const opts = { method, headers: { 'Content-Type': 'application/json' } };
      if (body) opts.body = JSON.stringify(body);
      const res = await fetch(url, opts);
      return await res.json();
    } catch (e) { return { error: 'Network error' }; }
  },

  esc(str) {
    if(!str) return '';
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  },

  toast(msg) {
    const t = document.getElementById('toast');
    document.getElementById('toastMsg').innerText = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
  }
};

document.addEventListener('DOMContentLoaded', () => App.init());
</script>
</body>
</html>
