        <div class="nav-link" onclick="App.navigate('admin-dash')" id="nav-admin-dash"><i class="fas fa-chart-pie"></i> Dashboard</div>
        <div class="nav-link" onclick="App.navigate('admin-depts')" id="nav-admin-depts"><i class="fas fa-building"></i> Departments</div>
